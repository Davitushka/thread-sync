    {
      "id": 410,
      "title": "Brute-force: попытки 401/403 по IP (5-мин окна)",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 7,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse-siem"
      },
      "description": "T1110 / T1110.001. Количество запросов с кодом 401/403 на auth-пути по 5-минутным окнам. Порог >10 за 2 мин → алерт BruteForceDetected.",
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse-siem"
          },
          "format": 0,
          "rawSql": "SELECT toStartOfFiveMinutes(timestamp) AS t, toString(source_ip) AS ip, count() AS attempts FROM siem.events WHERE timestamp >= now() - INTERVAL 24 HOUR AND status_code IN (401, 403) AND (url_path LIKE '%auth%' OR url_path LIKE '%login%' OR url_path LIKE '%token%' OR url_path LIKE '%hubs%') GROUP BY t, ip ORDER BY t"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "sum",
            "max"
          ]
        }
      }
    },
    {
      "id": 411,
      "title": "Brute-force: топ IP (24ч)",
      "type": "table",
      "gridPos": {
        "x": 12,
        "y": 7,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse-siem"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse-siem"
          },
          "format": 1,
          "rawSql": "SELECT toString(source_ip) AS IP, count() AS Attempts, countIf(status_code = 401) AS code_401, countIf(status_code = 403) AS code_403, countIf(status_code = 200) AS Success_200, if(countIf(status_code = 200) > 0, '⚠ TAKEOVER?', '') AS Flag FROM siem.events WHERE timestamp >= now() - INTERVAL 24 HOUR AND (url_path LIKE '%auth%' OR url_path LIKE '%login%' OR url_path LIKE '%token%') AND source_ip IS NOT NULL GROUP BY source_ip HAVING Attempts > 3 ORDER BY Attempts DESC LIMIT 20",
          "meta": {
            "builderOptions": {
              "fields": []
            }
          }
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Attempts"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "thresholds",
                "value": {
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "orange",
                      "value": 5
                    },
                    {
                      "color": "red",
                      "value": 15
                    }
                  ]
                }
              },
              {
                "id": "color",
                "value": {
                  "mode": "thresholds"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Flag"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-text"
              },
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "Attempts",
            "desc": true
          }
        ]
      }
    },
    {
      "id": 420,
      "title": "SQL injection: события по времени (T1190)",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 15,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse-siem"
      },
      "description": "T1190. Запросы с SQL-паттернами в url_path: UNION, SELECT, DROP, xp_, encoded quotes.",
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse-siem"
          },
          "format": 0,
          "rawSql": "SELECT toStartOfMinute(timestamp) AS t, count() AS sqli_attempts FROM siem.events WHERE timestamp >= now() - INTERVAL 24 HOUR AND url_path IS NOT NULL AND (url_path ILIKE '%union%select%' OR url_path ILIKE '%drop%table%' OR url_path LIKE '%xp_%' OR url_path LIKE '%27%' OR url_path LIKE '%3B%' OR url_path LIKE '%22%') GROUP BY t ORDER BY t"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 25
          },
          "color": {
            "fixedColor": "red",
            "mode": "fixed"
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "displayMode": "hidden"
        }
      }
    },
