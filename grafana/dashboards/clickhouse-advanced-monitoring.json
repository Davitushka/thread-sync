{
  "title": "Advanced ClickHouse Monitoring (Prometheus)",
  "uid": "ch-advanced-monitoring",
  "version": 1,
  "refresh": "30s",
  "schemaVersion": 38,
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timezone": "browser",
  "tags": [
    "clickhouse",
    "prometheus",
