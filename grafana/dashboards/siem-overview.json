    {
      "id": 4,
      "title": "Recent Security Events",
      "description": "warning/error/critical по всем источникам; также **redis** (любой уровень), чтобы видеть кэш в том же потоке.",
      "type": "table",
      "gridPos": {
        "x": 12,
        "y": 11,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse-siem"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse-siem"
          },
          "rawSql": "SELECT formatDateTime(timestamp, '%H:%i:%S') AS Time, toString(source_type) AS Source, toString(severity) AS Severity, left(message, 55) AS Message, toString(source_ip) AS IP FROM siem.events WHERE timestamp >= now() - INTERVAL 24 HOUR AND (severity IN ('error','critical','warning') OR source_type = 'redis') ORDER BY timestamp DESC LIMIT 50",
          "format": 1
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Severity"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "critical": {
                        "color": "red",
                        "index": 0
                      },
                      "error": {
                        "color": "orange",
                        "index": 1
                      },
                      "warning": {
                        "color": "yellow",
                        "index": 2
                      }
                    }
                  }
                ]
              },
              {
                "id": "color",
                "value": {
                  "mode": "thresholds"
                }
              }
            ]
          }
        ]
      }
    },
