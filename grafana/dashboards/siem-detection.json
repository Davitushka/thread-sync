    {
      "id": 450,
      "title": "Account Takeover: brute-force → успешный вход (T1110)",
      "type": "table",
      "gridPos": {
        "x": 0,
        "y": 39,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse-siem"
      },
      "description": "IP с >5 ошибками авторизации за 15 мин И последующим успешным входом (200 на auth-путях) — признак захвата аккаунта.",
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse-siem"
          },
          "format": 1,
          "rawSql": "SELECT toString(source_ip) AS IP, user_id AS User, countIf(status_code IN (401,403)) AS Failed, countIf(status_code = 200) AS Success, min(timestamp) AS first_seen, max(timestamp) AS last_seen, if(countIf(status_code=200) > 0 AND countIf(status_code IN (401,403)) >= 5, '🚨 TAKEOVER RISK', '⚠ Monitoring') AS Risk FROM siem.events WHERE timestamp >= now() - INTERVAL 24 HOUR AND (url_path LIKE '%auth%' OR url_path LIKE '%login%' OR url_path LIKE '%token%') AND source_ip IS NOT NULL GROUP BY source_ip, user_id HAVING Failed > 0 ORDER BY Failed DESC LIMIT 20",
          "meta": {
            "builderOptions": {
              "fields": []
            }
          }
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Risk"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-text"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Failed"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "thresholds",
                "value": {
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "orange",
                      "value": 3
                    },
                    {
                      "color": "red",
                      "value": 5
                    }
                  ]
                }
              },
              {
                "id": "color",
                "value": {
                  "mode": "thresholds"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "Failed",
            "desc": true
          }
        ]
      }
    },
    {
