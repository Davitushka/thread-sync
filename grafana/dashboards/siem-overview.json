    {
      "id": 10,
      "title": "HTTP Status Code Distribution",
      "description": "События без HTTP (PG, Redis, …) попадают в «non-HTTP / N/A», чтобы панель не была пустой. Реальные коды — отдельные столбцы.",
      "type": "barchart",
      "gridPos": {
        "x": 0,
        "y": 31,
        "w": 8,
        "h": 8
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse-siem"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse-siem"
          },
          "rawSql": "SELECT Code, count() AS Events\nFROM (\n  SELECT\n    multiIf(\n      status_code IS NULL OR status_code = 0,\n      'non-HTTP / N/A',\n      toString(status_code)\n    ) AS Code\n  FROM siem.events\n  WHERE timestamp >= now() - INTERVAL 24 HOUR\n)\nGROUP BY Code\nORDER BY Events DESC\nLIMIT 20",
          "format": 1
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "options": {
        "orientation": "vertical",
        "xTickLabelRotation": 0,
        "barWidth": 0.6,
        "showValue": "auto",
        "xField": "Code"
      }
    },
    {
      "id": 11,
      "title": "GeoIP / страна или IP",
      "description": "Для GeoIP enrichment настройте siem-parser с MaxMind GeoIP или добавьте GeoIP модуль в Vector. Сейчас показывает агрегацию по IP.",
      "type": "table",
      "gridPos": {
        "x": 8,
        "y": 31,
        "w": 8,
        "h": 8
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse-siem"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse-siem"
          },
          "rawSql": "SELECT\n  multiIf(\n    geo_country_name IS NOT NULL AND length(trimBoth(toString(geo_country_name))) > 0,\n      toString(geo_country_name),\n    concat(toString(source_ip), ' (GeoIP не настроен)')\n  ) AS Location,\n  count() AS Events,\n  countIf(severity IN ('error','critical')) AS Threats\nFROM siem.events\nWHERE timestamp >= now() - INTERVAL 24 HOUR\n  AND source_ip IS NOT NULL\nGROUP BY Location\nORDER BY Events DESC\nLIMIT 25",
          "format": 1
        }
      ]
    },
    {
      "id": 12,
      "title": "Avg Response Time (ms)",
      "description": "Только события с duration_ms > 0 (.NET/nginx). Пустые минуты — норма.",
      "type": "timeseries",
      "gridPos": {
        "x": 16,
        "y": 31,
        "w": 8,
        "h": 8
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse-siem"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse-siem"
          },
          "rawSql": "SELECT toStartOfMinute(timestamp) AS t, round(avg(duration_ms), 2) AS avg_ms, round(quantile(0.95)(duration_ms), 2) AS p95_ms FROM siem.events WHERE timestamp >= now() - INTERVAL 24 HOUR AND duration_ms IS NOT NULL AND duration_ms > 0 GROUP BY t ORDER BY t",
          "format": 0
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 2
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "p95_ms"
            },
            "properties": [
              {
                "id": "custom.lineStyle",
                "value": {
                  "dash": [
                    10,
                    5
                  ],
                  "fill": "dash"
                }
              },
              {
                "id": "color",
                "value": {
                  "fixedColor": "orange",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      }
    },
