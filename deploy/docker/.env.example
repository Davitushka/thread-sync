# Скопируйте в deploy/docker/.env и подставьте свои значения.
# Запуск: docker compose --env-file deploy/docker/.env -f deploy/docker/docker-compose.yml up -d
#
# Содержимое secrets/clickhouse_password.txt должно совпадать с CLICKHOUSE_PASSWORD.

CLICKHOUSE_PASSWORD=ClickHousePass123!
POSTGRES_PASSWORD=PostgresCases123!

# Опционально: ключ для siem-parser (заголовок X-API-Key или Authorization: Bearer …)
# SIEM_PARSER_API_KEY=
