{
  "title": "Advanced ClickHouse Monitoring (Prometheus)",
  "uid": "ch-advanced-monitoring",
  "version": 1,
  "refresh": "30s",
  "schemaVersion": 38,
  "time": { "from": "now-24h", "to": "now" },
  "timezone": "browser",
  "tags": ["clickhouse", "prometheus", "siem"],
  "panels": [
    {
      "id": 1,
      "title": "Источник метрик",
      "type": "text",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 3 },
      "options": {
        "mode": "markdown",
        "content": "## Встроенный экспорт ClickHouse → Prometheus\n\nМетрики снимаются с **`clickhouse:9363`** (job `clickhouse` в Prometheus). **OpenTelemetry Collector не требуется.**\n\nЗапросы переведены на префиксы **`ClickHouseProfileEvents_*`** (события) и **`ClickHouseAsyncMetrics_*`** (асинхронные показатели вместо устаревших `ClickHouseMetrics_*` в части панелей)."
      },
      "transparent": true
    },
    {
      "id": 2,
      "title": "ProfileEvents: запросы / с",
      "description": "Суммарная интенсивность Query из встроенного счётчика CH (Prometheus).",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 3, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
      "targets": [
        { "refId": "A", "expr": "sum(rate(ClickHouseProfileEvents_Query{job=\"clickhouse\"}[2m]))", "legendFormat": "Query / s" },
        { "refId": "B", "expr": "sum(rate(ClickHouseProfileEvents_SelectQuery{job=\"clickhouse\"}[2m]))", "legendFormat": "SelectQuery / s" },
        { "refId": "C", "expr": "sum(rate(ClickHouseProfileEvents_InsertQuery{job=\"clickhouse\"}[2m]))", "legendFormat": "InsertQuery / s" }
      ],
      "fieldConfig": { "defaults": { "unit": "cps", "custom": { "lineWidth": 2, "fillOpacity": 12 } } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom" } }
    },
    {
      "id": 3,
      "title": "ProfileEvents: ошибки / с",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 3, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
      "targets": [
        { "refId": "A", "expr": "sum(rate(ClickHouseProfileEvents_FailedQuery{job=\"clickhouse\"}[2m]))", "legendFormat": "FailedQuery / s" },
        { "refId": "B", "expr": "sum(rate(ClickHouseProfileEvents_FailedInsertQuery{job=\"clickhouse\"}[2m]))", "legendFormat": "FailedInsert / s" }
      ],
      "fieldConfig": { "defaults": { "unit": "cps", "custom": { "lineWidth": 2, "fillOpacity": 12 } } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom" } }
    },
    {
      "id": 4,
      "title": "AsyncMetrics: память (resident)",
      "description": "Асинхронная метрика RSS; без OTel.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 10, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
      "targets": [
        { "refId": "A", "expr": "ClickHouseAsyncMetrics_MemoryResident{job=\"clickhouse\"}", "legendFormat": "resident" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "lineWidth": 2 } } },
      "options": { "tooltip": { "mode": "single" }, "legend": { "displayMode": "hidden" } }
    },
    {
      "id": 5,
      "title": "AsyncMetrics: свободно на диске (default)",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 10, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
      "targets": [
        { "refId": "A", "expr": "ClickHouseAsyncMetrics_DiskAvailable_default{job=\"clickhouse\"}", "legendFormat": "available" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "lineWidth": 2 } } },
      "options": { "tooltip": { "mode": "single" }, "legend": { "displayMode": "hidden" } }
    },
    {
      "id": 6,
      "title": "AsyncMetrics: части / куски",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 10, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
      "targets": [
        { "refId": "A", "expr": "ClickHouseAsyncMetrics_MaxPartCountForPartition{job=\"clickhouse\"}", "legendFormat": "max parts" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } } },
      "options": { "tooltip": { "mode": "single" }, "legend": { "displayMode": "hidden" } }
    }
  ]
}
