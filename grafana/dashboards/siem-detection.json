    {
      "id": 430,
      "title": "Privilege escalation: 401/403 → 200 на admin путях (T1068)",
      "type": "table",
      "gridPos": {
        "x": 0,
        "y": 23,
        "w": 14,
        "h": 8
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse-siem"
      },
      "description": "T1068, T1078.003. IP, у которых были отказы на admin-путях (401/403), а затем успех (200/201).",
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse-siem"
          },
          "format": 1,
          "rawSql": "SELECT toString(source_ip) AS IP, user_id, countIf(status_code IN (401,403)) AS denied, countIf(status_code IN (200,201,204)) AS granted, min(timestamp) AS first_attempt, max(timestamp) AS last_success FROM siem.events WHERE timestamp >= now() - INTERVAL 24 HOUR AND (url_path LIKE '%admin%' OR url_path LIKE '%manage%' OR url_path LIKE '%role%' OR url_path LIKE '%permission%') AND source_ip IS NOT NULL GROUP BY source_ip, user_id HAVING denied > 0 AND granted > 0 ORDER BY granted DESC LIMIT 20",
          "meta": {
            "builderOptions": {
              "fields": []
            }
          }
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "granted"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "thresholds",
                "value": {
                  "steps": [
                    {
                      "color": "transparent",
                      "value": null
                    },
                    {
                      "color": "red",
                      "value": 1
                    }
                  ]
                }
              },
              {
                "id": "color",
                "value": {
                  "mode": "thresholds"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true
      }
