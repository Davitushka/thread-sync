{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "SIEM-Lite",
  "version": "0.1.0",
  "identifier": "com.siem-lite.desktop",
  "build": {
    "frontendDist": "./frontend"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "SIEM-Lite",
        "width": 1360,
        "height": 860,
        "minWidth": 1040,
        "minHeight": 640,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
