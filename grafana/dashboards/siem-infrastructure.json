      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
          "expr": "rate(ClickHouseProfileEvents_SelectQuery{job=\"clickhouse\"}[2m])",
          "legendFormat": "SELECT/s"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
          "expr": "rate(ClickHouseProfileEvents_InsertQuery{job=\"clickhouse\"}[2m])",
          "legendFormat": "INSERT/s"
        }
      ],
      "fieldConfig": {
