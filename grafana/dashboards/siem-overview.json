    {
      "id": 8,
      "title": "Error Rate (24h)",
      "description": "Доля событий с severity error+critical. В ClickHouse целочисленное деление даёт 0 — используем Float64.",
      "type": "stat",
      "gridPos": {
        "x": 8,
        "y": 19,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse-siem"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse-siem"
          },
          "rawSql": "SELECT round(toFloat64(countMergeIf(event_count, toUInt8(severity) >= 3)) / nullIf(countMerge(event_count), 0) * 100, 2) AS error_pct FROM siem.events_per_minute_agg WHERE minute >= now() - INTERVAL 24 HOUR",
          "format": 1
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 5
              },
              {
                "color": "red",
                "value": 15
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      }
