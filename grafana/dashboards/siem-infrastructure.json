              { "color": "orange", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      }
    },

    {
      "id": 39,
      "title": "Total Events Ingested (24h)",
      "description": "Общее количество событий, записанных в ClickHouse за последние 24 часа.",
      "type": "stat",
      "gridPos": { "x": 18, "y": 43, "w": 6, "h": 4 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-siem" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-siem" },
          "rawSql": "SELECT count() AS total FROM siem.events WHERE timestamp >= now() - INTERVAL 24 HOUR",
          "format": 1
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      }
    }

  ]
