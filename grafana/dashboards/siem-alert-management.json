    {
      "id": 505,
      "title": "Среднее время закрытия (мин)",
      "type": "stat",
      "gridPos": {
        "x": 16,
        "y": 4,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse-siem"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse-siem"
          },
          "format": 1,
          "rawSql": "SELECT round(avg(dateDiff('minute', triggered_at, acknowledged_at)), 1) AS MTTA_min FROM siem.alerts WHERE status IN ('acknowledged','resolved') AND acknowledged_at IS NOT NULL AND triggered_at >= now() - INTERVAL 7 DAY"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 1,
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 30
              },
              {
                "color": "red",
                "value": 60
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "id": 506,
      "title": "% False Positive",
      "type": "stat",
      "gridPos": {
        "x": 20,
        "y": 4,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse-siem"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse-siem"
          },
          "format": 1,
          "rawSql": "SELECT round(toFloat64(countIf(status='false_positive')) / nullIf(count(), 0) * 100, 1) AS fp_pct FROM siem.alerts WHERE triggered_at >= now() - INTERVAL 7 DAY"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 10
              },
              {
                "color": "red",
                "value": 30
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "id": 510,
      "title": "Алерты по времени (7 дней)",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 16,
        "h": 8
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse-siem"
      },
      "description": "Частота срабатывания алертов по дням. Рост может означать новую атаку или ложные срабатывания.",
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse-siem"
          },
          "format": 0,
          "rawSql": "SELECT toStartOfHour(triggered_at) AS t, countIf(toString(severity) = 'critical') AS critical, countIf(toString(severity) = 'high') AS high, countIf(toString(severity) = 'medium') AS medium, countIf(toString(severity) = 'low') AS low FROM siem.alerts WHERE triggered_at >= now() - INTERVAL 7 DAY GROUP BY t ORDER BY t"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "critical"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#E02F44",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "high"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#FA6400",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "medium"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#FF9830",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "low"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#3DC932",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "sum"
          ]
        }
      }
    },
    {
      "id": 511,
      "title": "По правилам (7 дней)",
      "type": "barchart",
      "gridPos": {
        "x": 16,
        "y": 8,
        "w": 8,
        "h": 8
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse-siem"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse-siem"
          },
          "format": 1,
          "rawSql": "SELECT rule_id AS Rule, count() AS Fired, countIf(status='false_positive') AS FP FROM siem.alerts WHERE triggered_at >= now() - INTERVAL 7 DAY GROUP BY rule_id ORDER BY Fired DESC LIMIT 15"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "options": {
        "orientation": "horizontal",
        "xField": "Rule",
        "barWidth": 0.7,
        "showValue": "auto"
      }
    },
    {
      "id": 520,
      "title": "Все активные алерты",
      "type": "table",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 24,
        "h": 10
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse-siem"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse-siem"
          },
          "format": 1,
          "rawSql": "SELECT formatDateTime(triggered_at, '%Y-%m-%d %H:%i:%S') AS Triggered, rule_id AS Rule, rule_title AS Title, toString(severity) AS Severity, toString(source_ip) AS IP, user_id AS User, left(description, 70) AS Description, toString(status) AS Status, acknowledged_by AS AckBy, arrayStringConcat(mitre_tags, ', ') AS MITRE FROM siem.alerts WHERE triggered_at >= now() - INTERVAL 7 DAY ORDER BY triggered_at DESC LIMIT 100",
          "meta": {
            "builderOptions": {
              "fields": []
            }
          }
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Severity"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "critical": {
                        "color": "red",
                        "index": 0
                      },
                      "high": {
                        "color": "orange",
                        "index": 1
                      },
                      "medium": {
                        "color": "yellow",
                        "index": 2
                      },
                      "low": {
                        "color": "green",
                        "index": 3
                      }
                    }
                  }
                ]
              },
              {
                "id": "color",
                "value": {
                  "mode": "thresholds"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Status"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "new": {
                        "color": "red",
                        "index": 0
                      },
                      "acknowledged": {
                        "color": "yellow",
                        "index": 1
                      },
                      "resolved": {
                        "color": "green",
                        "index": 2
                      },
                      "false_positive": {
                        "color": "blue",
                        "index": 3
                      }
                    }
                  }
                ]
              },
              {
                "id": "color",
                "value": {
                  "mode": "thresholds"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "Triggered",
            "desc": true
          }
        ]
      }
    },
    {
      "id": 530,
      "title": "False Positive по правилам (тренд)",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 26,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse-siem"
      },
      "description": "Правила с высоким % FP — кандидаты на пересмотр порогов. Рекомендовано: FP < 10%.",
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse-siem"
          },
          "format": 0,
          "rawSql": "SELECT toStartOfDay(triggered_at) AS t, rule_id, countIf(status='false_positive') AS fp_count, count() AS total FROM siem.alerts WHERE triggered_at >= now() - INTERVAL 7 DAY GROUP BY t, rule_id ORDER BY t"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 531,
      "title": "Prometheus: число firing-алертов",
      "type": "stat",
      "gridPos": {
        "x": 12,
        "y": 26,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-siem"
      },
      "description": "Счётчик активных серий `ALERTS{alertstate=\"firing\"}`. Показывает **0**, если правила не загружены или ничего не firing — это нормально; детали см. Prometheus → Alerts. Запрос с `or vector(0)` устраняет «No data».",
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-siem"
          },
          "expr": "count(ALERTS{alertstate=\"firing\"}) or vector(0)",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        }
      }
    },
    {
      "id": 540,
      "title": "Частота алертов по правилам (heatmap-proxy: часы × правила)",
      "type": "table",
      "gridPos": {
        "x": 0,
        "y": 34,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse-siem"
      },
      "description": "Суточное распределение срабатываний по правилам — помогает увидеть шаблоны (атаки по расписанию, ночные брутфорсы).",
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse-siem"
          },
          "format": 1,
          "rawSql": "SELECT rule_id AS Rule, countIf(toHour(triggered_at) BETWEEN 0 AND 5)   AS night_00_06, countIf(toHour(triggered_at) BETWEEN 6 AND 11)  AS morning_06_12, countIf(toHour(triggered_at) BETWEEN 12 AND 17) AS day_12_18, countIf(toHour(triggered_at) BETWEEN 18 AND 23) AS evening_18_24, count() AS Total FROM siem.alerts WHERE triggered_at >= now() - INTERVAL 7 DAY GROUP BY rule_id ORDER BY Total DESC",
          "meta": {
            "builderOptions": {
              "fields": []
            }
          }
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": "night|morning|day|evening"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "thresholds",
                "value": {
                  "steps": [
                    {
                      "color": "transparent",
                      "value": null
                    },
                    {
                      "color": "light-yellow",
                      "value": 1
                    },
                    {
                      "color": "orange",
                      "value": 5
                    },
                    {
                      "color": "red",
                      "value": 10
                    }
                  ]
                }
              },
              {
                "id": "color",
                "value": {
                  "mode": "thresholds"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true
      }
    },
    {
      "id": 541,
      "title": "Loki: логи контейнеров SIEM",
      "description": "Стрим логов ключевых сервисов из Loki (docker_sd → label container).",
      "type": "logs",
      "gridPos": {
        "x": 0,
        "y": 42,
        "w": 24,
        "h": 10
      },
      "datasource": {
        "type": "loki",
        "uid": "loki-siem"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki-siem"
          },
          "editorMode": "code",
          "expr": "{container=~\"siem-clickhouse|siem-parser|siem-correlator|siem-vector-aggregator|siem-admin|siem-grafana|siem-prometheus|siem-redpanda\"}",
          "queryType": "range"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    }
  ]
}
