    {
      "id": 312,
      "title": "Redpanda: offset consumer group → ClickHouse (siem.events)",
      "type": "table",
      "gridPos": {
        "x": 0,
        "y": 15,
        "w": 12,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-siem"
      },
      "description": "Committed offset группы clickhouse_siem_events (redpanda_kafka_consumer_group_committed_offset). Рост при активном чтении в ClickHouse.",
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-siem"
          },
          "expr": "redpanda_kafka_consumer_group_committed_offset{topic=\"siem.events\",group=\"clickhouse_siem_events\"}",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "renameByName": {
              "partition": "partition",
              "Value": "offset"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "inspect": false
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "partition",
            "desc": false
          }
        ]
      }
    },
