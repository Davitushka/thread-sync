          },
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      }
    },

    {
      "id": 36,
      "title": "Detection Alerts/sec",
      "description": "Скорость генерации алертов detection engine за последние 5 минут.",
      "type": "stat",
      "gridPos": { "x": 0, "y": 43, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
          "expr": "sum(rate(detection_alerts_fired_total{job=\"detection-engine\"}[5m]))",
          "legendFormat": "Alerts/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "thresholds" },
