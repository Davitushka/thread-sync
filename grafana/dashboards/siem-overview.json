                      "acknowledged": {
                        "color": "yellow",
                        "index": 1
                      },
                      "resolved": {
                        "color": "green",
                        "index": 2
                      }
                    }
                  }
                ]
              },
              {
                "id": "color",
                "value": {
                  "mode": "thresholds"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "sortBy": [
          {
            "displayName": "Time",
            "desc": true
          }
        ]
      }
    },
    {
      "id": 14,
      "title": "Задержка записи (timestamp → ingest_ts)",
      "description": "Реальный лаг для потока Vector→Kafka→ClickHouse. Метрики siem-parser здесь не используются (парсер — отдельный путь POST /parse).",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 47,
        "w": 12,
        "h": 6
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse-siem"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse-siem"
          },
          "rawSql": "SELECT\n  toStartOfMinute(ingest_ts) AS t,\n  round(avg(greatest(dateDiff('millisecond', timestamp, ingest_ts), 0)), 1) AS avg_lag_ms,\n  round(quantile(0.95)(greatest(dateDiff('millisecond', timestamp, ingest_ts), 0)), 1) AS p95_lag_ms\nFROM siem.events\nWHERE timestamp >= now() - INTERVAL 24 HOUR\nGROUP BY t\nHAVING count() > 0\nORDER BY t",
          "format": 0
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "p95_lag_ms"
            },
            "properties": [
              {
                "id": "custom.lineStyle",
                "value": {
                  "dash": [
                    10,
                    5
                  ],
                  "fill": "dash"
                }
              },
              {
                "id": "color",
                "value": {
                  "fixedColor": "orange",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      }
    },
