{
  "title": "SIEM-Lite — Infrastructure",
  "uid": "siem-infrastructure",
  "version": 1,
  "refresh": "30s",
  "schemaVersion": 38,
  "time": { "from": "now-24h", "to": "now" },
  "timezone": "browser",
  "tags": ["siem", "infrastructure", "monitoring"],
  "graphTooltip": 1,
  "editable": true,
  "links": [
    { "title": "Overview", "type": "link", "url": "/d/siem-overview", "keepTime": true, "icon": "dashboard" },
    { "title": "Detection", "type": "link", "url": "/d/siem-detection", "keepTime": true, "icon": "dashboard" },
    { "title": "Operations", "type": "link", "url": "/d/siem-operations", "keepTime": true, "icon": "dashboard" },
    { "title": "Validation", "type": "link", "url": "/d/siem-validation", "keepTime": true, "icon": "dashboard" }
  ],
  "panels": [
    {
      "id": 100,
      "type": "text",
      "title": "",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 3 },
      "options": {
        "mode": "markdown",
        "content": "## SIEM-Lite Infrastructure Monitoring\n\nХост-машина + контейнеры + компоненты SIEM стека. **node-exporter** (порт 9101) + **cAdvisor** (порт 8081) + метрики компонентов.\n\n- События и дашборды безопасности — [Overview](/d/siem-overview)\n- Операционные метрики — [Operations](/d/siem-operations)\n- Пошаговые проверки — [Validation](/d/siem-validation)"
      },
      "transparent": true
    },

    {
      "id": 101,
      "title": "CPU Usage (%)",
      "description": "Хост CPU: 100 - idle. Окрашены по порогам: зелёный <60%, оранжевый 60-80%, красный >80%.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 3, "w": 8, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
          "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{mode=\"idle\",job=\"node-exporter\"}[2m])) * 100)",
          "legendFormat": "CPU {{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "lineWidth": 2, "fillOpacity": 20 },
          "thresholds": { "mode": "percentage", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 60 }, { "color": "red", "value": 80 }] },
          "color": { "mode": "thresholds" }
        }
      }
    },

    {
      "id": 102,
      "title": "Memory Usage (%)",
      "description": "Хост RAM: (1 - Available/Total) * 100. Порог: зелёный <70%, оранжевый 70-85%, красный >85%.",
      "type": "gauge",
      "gridPos": { "x": 8, "y": 3, "w": 4, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
          "expr": "(1 - (node_memory_MemAvailable_bytes{job=\"node-exporter\"} / node_memory_MemTotal_bytes{job=\"node-exporter\"})) * 100",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": { "mode": "percentage", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 70 }, { "color": "red", "value": 85 }] },
          "color": { "mode": "thresholds" },
          "min": 0,
          "max": 100
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": false, "showThresholdMarkers": true }
    },

    {
      "id": 103,
      "title": "Disk Usage (%)",
      "description": "Хост Disk: (1 - Available/Size) * 100 для /. Порог: зелёный <70%, оранжевый 70-85%, красный >85%.",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 3, "w": 4, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
          "expr": "(1 - (node_filesystem_avail_bytes{job=\"node-exporter\",mountpoint=\"/\",fstype!=\"tmpfs\"} / node_filesystem_size_bytes{job=\"node-exporter\",mountpoint=\"/\",fstype!=\"tmpfs\"})) * 100",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": { "mode": "percentage", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 70 }, { "color": "red", "value": 85 }] },
          "color": { "mode": "thresholds" },
          "min": 0,
          "max": 100
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": false, "showThresholdMarkers": true }
    },

    {
      "id": 104,
      "title": "Network I/O (bytes/sec)",
      "description": "Хост Network: RX (входящий) и TX (исходящий) трафик.",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 3, "w": 8, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
          "expr": "sum(rate(node_network_receive_bytes_total{job=\"node-exporter\",device!=\"lo\"}[2m]))",
          "legendFormat": "RX (received)"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
          "expr": "sum(rate(node_network_transmit_bytes_total{job=\"node-exporter\",device!=\"lo\"}[2m]))",
          "legendFormat": "TX (transmitted)"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps", "custom": { "lineWidth": 2, "fillOpacity": 15 } }
      }
    },

    {
      "id": 105,
      "title": "System Load (1m, 5m, 15m)",
      "description": "Load average хоста. Если > количества CPU — перегрузка.",
      "type": "stat",
      "gridPos": { "x": 0, "y": 9, "w": 8, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus-siem" }, "expr": "node_load1{job=\"node-exporter\"}", "legendFormat": "1 min", "instant": true },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus-siem" }, "expr": "node_load5{job=\"node-exporter\"}", "legendFormat": "5 min", "instant": true },
        { "refId": "C", "datasource": { "type": "prometheus", "uid": "prometheus-siem" }, "expr": "node_load15{job=\"node-exporter\"}", "legendFormat": "15 min", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 4 }, { "color": "red", "value": 8 }] },
          "color": { "mode": "thresholds" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" }
    },

    {
      "id": 106,
      "title": "Uptime",
      "description": "Время работы хоста с момента загрузки.",
      "type": "stat",
      "gridPos": { "x": 8, "y": 9, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus-siem" }, "expr": "time() - node_boot_time_seconds{job=\"node-exporter\"}", "instant": true }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "fixedColor": "blue", "mode": "fixed" } }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" }
    },

    {
      "id": 107,
      "title": "CPU Temperature (°C)",
      "description": "Температура CPU хоста (если доступна через node-exporter). Может быть null если датчик не поддерживается.",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 9, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus-siem" }, "expr": "node_hwmon_temp_celsius{job=\"node-exporter\"}", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 60 }, { "color": "red", "value": 75 }] },
          "color": { "mode": "thresholds" },
          "min": 0,
          "max": 100
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": false, "showThresholdMarkers": true }
    },

    {
      "id": 108,
      "title": "Disk I/O (reads/writes per sec)",
      "description": "Хост Disk I/O: операции чтения и записи в секунду.",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 9, "w": 8, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus-siem" }, "expr": "sum(rate(node_disk_reads_completed_total{job=\"node-exporter\"}[2m]))", "legendFormat": "Reads/s" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus-siem" }, "expr": "sum(rate(node_disk_writes_completed_total{job=\"node-exporter\"}[2m]))", "legendFormat": "Writes/s" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "lineWidth": 2, "fillOpacity": 15 } }
      }
    },

    {
      "id": 200,
      "title": "Container CPU Usage (%)",
      "description": "Per-container CPU usage через cAdvisor. Сортировка по убыванию.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 13, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
          "expr": "sum by(name) (rate(container_cpu_usage_seconds_total{job=\"cadvisor\",name!=\"\",image!=\"\"}[2m])) * 100",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "thresholds": { "mode": "percentage", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 50 }, { "color": "red", "value": 80 }] },
          "color": { "mode": "thresholds" }
        }
      }
    },

    {
      "id": 201,
      "title": "Container Memory Usage (bytes)",
      "description": "Per-container RAM usage через cAdvisor.",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 13, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
          "expr": "container_memory_usage_bytes{job=\"cadvisor\",name!=\"\",image!=\"\"}",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "lineWidth": 2, "fillOpacity": 15 } }
      }
    },

    {
      "id": 202,
      "title": "Container Network RX/TX",
      "description": "Сетевой трафик контейнеров (суммарно по всем интерфейсам).",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 19, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
          "expr": "sum by(name) (rate(container_network_receive_bytes_total{job=\"cadvisor\",name!=\"\",image!=\"\",interface!~\"(lo|docker|veth).*\"}[2m]))",
          "legendFormat": "{{name}} RX"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
          "expr": "sum by(name) (rate(container_network_transmit_bytes_total{job=\"cadvisor\",name!=\"\",image!=\"\",interface!~\"(lo|docker|veth).*\"}[2m]))",
          "legendFormat": "{{name}} TX"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps", "custom": { "lineWidth": 2, "fillOpacity": 12 } }
      }
    },

    {
      "id": 203,
      "title": "Top 5 Containers by CPU",
      "description": "Топ-5 контейнеров по среднему CPU за 5 минут.",
      "type": "barchart",
      "gridPos": { "x": 12, "y": 19, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
          "expr": "topk(5, sum by(name) (rate(container_cpu_usage_seconds_total{job=\"cadvisor\",name!=\"\",image!=\"\"}[5m]))) * 100",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        { "id": "organize", "options": { "renameByName": { "name": "Container", "Value": "CPU %" } } }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent" },
        "overrides": [{ "matcher": { "id": "byName", "options": "CPU %" }, "properties": [{ "id": "custom.displayMode", "value": "gradient-gauge" }] }]
      },
      "options": { "orientation": "horizontal", "xField": "Container", "barWidth": 0.7, "showValue": "auto" }
    },

    {
      "id": 204,
      "title": "Container Count (Running)",
      "description": "Количество запущенных контейнеров (имеющих потребление памяти).",
      "type": "stat",
      "gridPos": { "x": 0, "y": 25, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus-siem" }, "expr": "count(container_memory_usage_bytes{job=\"cadvisor\",name!=\"\",image!=\"\"})", "instant": true }
      ],
      "fieldConfig": { "defaults": { "color": { "fixedColor": "blue", "mode": "fixed" } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" }
    },

    {
      "id": 205,
      "title": "OOM Kills (24h)",
      "description": "Контейнеры, получившие OOM kill за последние 24 часа.",
      "type": "stat",
      "gridPos": { "x": 4, "y": 25, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus-siem" }, "expr": "sum(increase(container_oom_events_total{job=\"cadvisor\",name!=\"\",image!=\"\"}[24h]))", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 3 }] },
          "color": { "mode": "thresholds" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" }
    },

    {
      "id": 206,
      "title": "Total Container CPU (%)",
      "description": "Суммарное CPU всех контейнеров.",
      "type": "gauge",
      "gridPos": { "x": 8, "y": 25, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus-siem" }, "expr": "sum(rate(container_cpu_usage_seconds_total{job=\"cadvisor\",name!=\"\",image!=\"\"}[2m])) * 100", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": { "mode": "percentage", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 60 }, { "color": "red", "value": 80 }] },
          "color": { "mode": "thresholds" },
          "min": 0,
          "max": 100
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": false, "showThresholdMarkers": true }
    },

    {
      "id": 207,
      "title": "Total Container Memory (bytes)",
      "description": "Суммарная RAM всех контейнеров.",
      "type": "stat",
      "gridPos": { "x": 12, "y": 25, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus-siem" }, "expr": "sum(container_memory_usage_bytes{job=\"cadvisor\",name!=\"\",image!=\"\"})", "instant": true }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes", "color": { "fixedColor": "purple", "mode": "fixed" } }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" }
    },

    {
      "id": 208,
      "title": "Host IP Addresses",
      "description": "IP адреса хоста (из node-exporter).",
      "type": "table",
      "gridPos": { "x": 16, "y": 25, "w": 8, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
          "expr": "node_network_address_info{job=\"node-exporter\"}",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        { "id": "filterFieldsByName", "options": { "include": { "pattern": "^(name|address|Value)$" } } },
        { "id": "organize", "options": { "renameByName": { "name": "Interface", "address": "IP Address" } } }
      ],
      "options": { "showHeader": true }
    },

    {
      "id": 300,
      "title": "Component UP/DOWN Status",
      "description": "Статус всех компонентов SIEM стека. Зелёный = UP, красный = DOWN.",
      "type": "table",
      "gridPos": { "x": 0, "y": 29, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
          "expr": "up{job=~\"vector-aggregator|siem-parser|redpanda|clickhouse|detection-engine|correlator|alertmanager|prometheus|node-exporter|cadvisor|grafana|loki|minio|redis\"}",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "host": true }, "renameByName": { "job": "Component", "Value": "UP" } } }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "inspect": false },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "color": { "mode": "thresholds" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "UP" }, "properties": [
            { "id": "custom.displayMode", "value": "color-background" },
            { "id": "mappings", "value": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red", "index": 0 }, "1": { "text": "UP", "color": "green", "index": 1 } } }] }
          ]}
        ]
      },
      "options": { "showHeader": true, "sortBy": [{ "displayName": "Component", "desc": false }] }
    },

    {
      "id": 301,
      "title": "Vector Throughput (events/sec)",
      "description": "Vector: входящие события через HTTP ingest и отправка в Kafka.",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 29, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus-siem" }, "expr": "rate(vector_component_received_events_total{job=\"vector-aggregator\",component_id=\"http_ingest\"}[2m])", "legendFormat": "HTTP ingest recv /s" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus-siem" }, "expr": "rate(vector_component_sent_events_total{job=\"vector-aggregator\",component_id=\"to_redpanda\"}[2m])", "legendFormat": "Kafka sink sent /s" }
      ],
      "fieldConfig": { "defaults": { "unit": "cps", "custom": { "lineWidth": 2, "fillOpacity": 15 } } }
    },

    {
      "id": 302,
      "title": "Rust Parser Latency p99 (ms)",
      "description": "siem-parser p99 latency парсинга. SLA: <5ms. Порог: зелёный <5ms, оранжевый 5-10ms, красный >10ms.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 35, "w": 8, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
          "expr": "histogram_quantile(0.99, rate(siem_parser_parse_duration_seconds_bucket{job=\"siem-parser\"}[2m])) * 1000",
          "legendFormat": "p99 latency"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 5 }, { "color": "red", "value": 10 }] },
          "color": { "mode": "thresholds" }
        }
      }
    },

    {
      "id": 303,
      "title": "Redpanda Consumer Lag",
      "description": "Lag consumer group clickhouse_siem_events. Порог: зелёный <1k, оранжевый 1k-10k, красный >10k.",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 35, "w": 8, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
          "expr": "siem:kafka_consumer_lag:sum",
          "legendFormat": "Total lag"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1000 }, { "color": "red", "value": 10000 }] },
          "color": { "mode": "thresholds" }
        }
      }
    },

    {
      "id": 304,
      "title": "ClickHouse Queries/s",
      "description": "ClickHouse: скорость SELECT и INSERT запросов.",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 35, "w": 8, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus-siem" }, "expr": "rate(ClickHouseProfileEvents_SelectQuery{job=\"clickhouse\"}[2m])", "legendFormat": "SelectQuery /s" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus-siem" }, "expr": "rate(ClickHouseProfileEvents_InsertQuery{job=\"clickhouse\"}[2m])", "legendFormat": "InsertQuery /s" },
        { "refId": "C", "datasource": { "type": "prometheus", "uid": "prometheus-siem" }, "expr": "rate(ClickHouseProfileEvents_FailedQuery{job=\"clickhouse\"}[2m])", "legendFormat": "FailedQuery /s" }
      ],
      "fieldConfig": { "defaults": { "unit": "cps", "custom": { "lineWidth": 2, "fillOpacity": 12 } } }
    },

    {
      "id": 305,
      "title": "Detection Alerts/sec",
      "description": "Detection Engine: скорость срабатывания алертов.",
      "type": "stat",
      "gridPos": { "x": 0, "y": 41, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus-siem" }, "expr": "sum(rate(detection_alerts_fired_total[5m]))", "instant": true }
      ],
      "fieldConfig": { "defaults": { "unit": "cps", "decimals": 2, "color": { "fixedColor": "red", "mode": "fixed" } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" }
    },

    {
      "id": 306,
      "title": "Parse Error Rate (%)",
      "description": "Доля событий с ошибкой парсинга. Порог: зелёный <1%, оранжевый 1-5%, красный >5%.",
      "type": "gauge",
      "gridPos": { "x": 4, "y": 41, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
          "expr": "(siem:parser_events_error:rate5m / (siem:parser_events_ok:rate5m + siem:parser_events_error:rate5m)) * 100",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": { "mode": "percentage", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 5 }] },
          "color": { "mode": "thresholds" },
          "min": 0,
          "max": 100
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": false, "showThresholdMarkers": true }
    },

    {
      "id": 307,
      "title": "Active Prometheus Alerts",
      "description": "Количество firing алертов в Prometheus.",
      "type": "stat",
      "gridPos": { "x": 8, "y": 41, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus-siem" }, "expr": "count(ALERTS{alertstate=\"firing\"}) or vector(0)", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 5 }] },
          "color": { "mode": "thresholds" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" }
    },

    {
      "id": 308,
      "title": "Detection Events/sec",
      "description": "Detection Engine: скорость обработки событий из Kafka.",
      "type": "stat",
      "gridPos": { "x": 12, "y": 41, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus-siem" }, "expr": "sum(rate(detection_events_processed_total[5m]))", "instant": true }
      ],
      "fieldConfig": { "defaults": { "unit": "cps", "decimals": 0, "color": { "fixedColor": "blue", "mode": "fixed" } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" }
    },

    {
      "id": 309,
      "title": "Total Events Ingested (24h)",
      "description": "Общее количество событий в ClickHouse за 24 часа.",
      "type": "stat",
      "gridPos": { "x": 16, "y": 41, "w": 4, "h": 4 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-siem" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-siem" },
          "rawSql": "SELECT count() AS Total FROM siem.events WHERE timestamp >= now() - INTERVAL 24 HOUR",
          "format": 1
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "fixedColor": "blue", "mode": "fixed" } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" }
    },

    {
      "id": 310,
      "title": "Parse Errors (24h)",
      "description": "Количество событий с ошибкой парсинга за 24 часа.",
      "type": "stat",
      "gridPos": { "x": 20, "y": 41, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus-siem" }, "expr": "sum(increase(siem_parser_events_parsed_total{status=\"error\"}[24h]))", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 100 }, { "color": "red", "value": 1000 }] },
          "color": { "mode": "thresholds" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" }
    }
  ]
}
