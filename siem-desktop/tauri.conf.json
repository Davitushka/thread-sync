{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "SIEM-Lite",
  "version": "0.1.0",
  "identifier": "com.siem-lite.desktop",
  "build": {
    "devUrl": "http://localhost:8091",
    "frontendDist": "http://localhost:8091"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "SIEM-Lite Operator",
        "width": 1360,
        "height": 860,
        "minWidth": 1040,
        "minHeight": 640,
        "center": true,
        "resizable": true,
        "url": "http://localhost:8091"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
