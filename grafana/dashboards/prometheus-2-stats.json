{
  "title": "Prometheus 2.x — состояние TSDB",
  "uid": "siem-prometheus-2-stats",
  "version": 1,
  "refresh": "30s",
  "schemaVersion": 38,
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timezone": "browser",
  "tags": [
    "prometheus",
    "monitoring",
    "siem"
  ],
  "panels": [
    {
      "id": 1,
      "title": "ℹ️ О дашборде TSDB",
      "type": "text",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 3
      },
      "options": {
        "mode": "markdown",
        "content": "## Prometheus TSDB — состояние базы данных временных рядов\n\n**Почему «мало движения»:** в дев-стеке TSDB быстро выходит на плато: рядов ~8–15k, append rate почти константа, `engine_queries` часто 0 между редкими запросами. Это **не баг**.\n\nНиже добавлена панель **ряды + чанки + скорость создания** — больше линий и смысла при сравнении нагрузки.\n\n**SIEM-события** смотрите в ClickHouse (`siem.events`) и дашборде **SIEM-Lite Overview**.\n\n---\n**Логи Docker:** внизу дашборда панель **«Loki: логи контейнеров SIEM»** (Promtail → Loki). Фильтр по `container` именам контейнеров."
      },
      "transparent": true
    },
    {
      "id": 2,
      "title": "Ряды в head TSDB",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 3,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-siem"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "prometheus_tsdb_head_series{job=\"prometheus\"} or vector(0)",
          "legendFormat": "series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "displayMode": "hidden"
        }
      }
    },
    {
      "id": 3,
      "title": "Append sample rate",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 3,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-siem"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(prometheus_tsdb_head_samples_appended_total{job=\"prometheus\"}[2m]) or vector(0)",
          "legendFormat": "samples/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "custom": {
            "lineWidth": 2
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "displayMode": "hidden"
        }
      }
    },
    {
      "id": 4,
      "title": "Активные запросы",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 11,
        "w": 12,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-siem"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "prometheus_engine_queries{job=\"prometheus\"} or vector(0)",
          "legendFormat": "queries"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "displayMode": "hidden"
        }
      }
    },
    {
      "id": 5,
      "title": "Alertmanager targets discovered",
      "type": "stat",
      "gridPos": {
        "x": 12,
        "y": 11,
        "w": 12,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-siem"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "prometheus_notifications_alertmanagers_discovered{job=\"prometheus\"} or vector(0)",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "id": 6,
      "title": "TSDB head: ряды, чанки, создание",
      "description": "Несколько шкал на одном графике; для bytes/chunks смотрите относительную динамику.",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 18,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-siem"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "prometheus_tsdb_head_series{job=\"prometheus\"} or vector(0)",
          "legendFormat": "head series"
        },
        {
          "refId": "B",
          "expr": "prometheus_tsdb_head_chunks{job=\"prometheus\"} or vector(0)",
          "legendFormat": "head chunks"
        },
        {
          "refId": "C",
          "expr": "rate(prometheus_tsdb_head_series_created_total{job=\"prometheus\"}[5m]) or vector(0)",
          "legendFormat": "series created/s"
        },
        {
          "refId": "D",
          "expr": "rate(prometheus_tsdb_head_chunks_created_total{job=\"prometheus\"}[5m]) or vector(0)",
          "legendFormat": "chunks created/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 7,
      "title": "Сэмплов за последний scrape (по job)",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 26,
        "w": 24,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-siem"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (job) (scrape_samples_scraped)",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "table",
          "placement": "right"
        }
      }
    },
    {
      "id": 8,
      "title": "Loki: логи контейнеров SIEM",
      "description": "Стрим логов ключевых сервисов из Loki (docker_sd → label container).",
      "type": "logs",
      "gridPos": {
        "x": 0,
        "y": 33,
        "w": 24,
        "h": 10
      },
      "datasource": {
        "type": "loki",
        "uid": "loki-siem"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki-siem"
          },
          "editorMode": "code",
          "expr": "{container=~\"siem-clickhouse|siem-parser|siem-correlator|siem-vector-aggregator|siem-admin|siem-grafana|siem-prometheus|siem-redpanda\"}",
          "queryType": "range"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    }
  ]
}
