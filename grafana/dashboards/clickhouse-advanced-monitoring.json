    },
    {
      "id": 7,
      "title": "Вставка: строки и байты / с",
      "description": "Интенсивность Insert из ProfileEvents — обычно заметнее, чем «плато» по RAM.",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 17,
        "w": 12,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-siem"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(ClickHouseProfileEvents_InsertedRows{job=\"clickhouse\"}[2m])",
          "legendFormat": "rows/s"
        },
        {
          "refId": "B",
          "expr": "rate(ClickHouseProfileEvents_InsertedBytes{job=\"clickhouse\"}[2m])",
          "legendFormat": "bytes/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 12
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "bytes/s"
            },
            "properties": [
              {
                "id": "unit",
                "value": "Bps"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "rows/s"
            },
            "properties": [
              {
                "id": "unit",
                "value": "cps"
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 8,
      "title": "Чтение сжатых данных / с",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 17,
        "w": 12,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-siem"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(ClickHouseProfileEvents_CompressedReadBufferBytes{job=\"clickhouse\"}[2m])",
          "legendFormat": "compressed read B/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "lineWidth": 2
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "displayMode": "hidden"
        }
      }
    },
    {
      "id": 9,
      "title": "Loki: логи контейнеров SIEM",
      "description": "Стрим логов ключевых сервисов из Loki (docker_sd → label container).",
      "type": "logs",
      "gridPos": {
        "x": 0,
        "y": 24,
        "w": 24,
        "h": 10
      },
      "datasource": {
        "type": "loki",
        "uid": "loki-siem"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki-siem"
          },
          "editorMode": "code",
          "expr": "{container=~\"siem-clickhouse|siem-parser|detection-engine|siem-correlator|siem-vector-aggregator|siem-admin|siem-grafana|siem-prometheus|siem-redpanda\"}",
          "queryType": "range"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    }
  ]
}
