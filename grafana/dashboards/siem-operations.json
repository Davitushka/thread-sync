    {
      "id": 316,
      "title": "Prometheus: firing alerts",
      "type": "stat",
      "gridPos": { "x": 0, "y": 30, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
      "description": "Количество активных записей в `ALERTS` (если заданы recording/alert rules). Ноль — норма.",
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
          "expr": "count(ALERTS{alertstate=\"firing\"}) or vector(0)",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" }
    },
    {
      "id": 317,
      "title": "Ошибки парсинга detection (24ч)",
      "type": "stat",
      "gridPos": { "x": 4, "y": 30, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
          "expr": "sum(increase(detection_parse_errors_total[24h]))",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" }
    },
    {
      "id": 318,
      "title": "Дропы алертов (24ч)",
      "type": "stat",
      "gridPos": { "x": 8, "y": 30, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
          "expr": "sum(increase(detection_alerts_dropped_total[24h]))",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" }
    },
    {
      "id": 319,
      "title": "Недавние алерты (ClickHouse)",
      "type": "table",
      "gridPos": { "x": 12, "y": 30, "w": 12, "h": 8 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-siem" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-siem" },
          "format": 1,
          "rawSql": "SELECT formatDateTime(triggered_at, '%m-%d %H:%M') AS t, rule_id, toString(severity), left(description, 48) AS msg FROM siem.alerts WHERE triggered_at >= now() - INTERVAL 7 DAY ORDER BY triggered_at DESC LIMIT 15",
          "meta": { "builderOptions": { "fields": [] } }
        }
      ],
      "options": { "showHeader": true }
    }
  ]
