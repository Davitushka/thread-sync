    },
    {
      "id": 605,
      "title": "Новые алерты (ClickHouse), 24h",
      "type": "stat",
      "gridPos": {
        "x": 18,
        "y": 3,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse-siem"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse-siem"
          },
          "format": 1,
          "rawSql": "SELECT count() AS new_alerts FROM siem.alerts WHERE status = 'new' AND triggered_at >= now() - INTERVAL 24 HOUR"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "id": 610,
      "title": "События, совпавшие с IoC (детально)",
      "type": "table",
      "gridPos": {
        "x": 0,
        "y": 7,
        "w": 24,
        "h": 10
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse-siem"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse-siem"
          },
          "format": 1,
          "rawSql": "SELECT formatDateTime(e.timestamp, '%Y-%m-%d %H:%i:%S') AS ts, toString(e.source_ip) AS ip, toString(e.severity) AS sev, e.user_id AS user, e.url_path AS path, t.feed AS ioc_feed, t.threat_label AS label, arrayStringConcat(t.tags, ', ') AS ioc_tags, left(e.message, 120) AS msg FROM siem.events e INNER JOIN siem.threat_intel t ON t.ioc_type = 'ipv4' AND t.ioc_value = toString(e.source_ip) WHERE e.timestamp >= now() - INTERVAL 24 HOUR ORDER BY e.timestamp DESC LIMIT 300"
        }
      ],
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "ts",
            "desc": true
          }
        ]
      }
    },
    {
      "id": 620,
      "title": "Каталог threat_intel",
      "type": "table",
      "gridPos": {
        "x": 0,
        "y": 17,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse-siem"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse-siem"
          },
          "format": 1,
          "rawSql": "SELECT ioc_type, ioc_value, feed, threat_label, arrayStringConcat(tags, ', ') AS tags, confidence, formatDateTime(first_seen, '%Y-%m-%d %H:%i:%S') AS first_seen, formatDateTime(last_seen, '%Y-%m-%d %H:%i:%S') AS last_seen FROM siem.threat_intel ORDER BY last_seen DESC LIMIT 500"
        }
      ],
      "options": {
        "showHeader": true
      }
    },
    {
      "id": 621,
      "title": "Loki: логи контейнеров SIEM",
      "description": "Стрим логов ключевых сервисов из Loki (docker_sd → label container).",
      "type": "logs",
      "gridPos": {
        "x": 0,
        "y": 25,
        "w": 24,
        "h": 10
      },
      "datasource": {
        "type": "loki",
        "uid": "loki-siem"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki-siem"
          },
          "editorMode": "code",
          "expr": "{container=~\"siem-clickhouse|siem-parser|siem-correlator|siem-vector-aggregator|siem-admin|siem-grafana|siem-prometheus|siem-redpanda\"}",
          "queryType": "range"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    }
