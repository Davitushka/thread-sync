# Скопируйте в deploy/docker/.env и подставьте свои значения.
# Запуск: docker compose --env-file deploy/docker/.env -f deploy/docker/docker-compose.yml up -d
#
# Содержимое secrets/clickhouse_password.txt должно совпадать с CLICKHOUSE_PASSWORD.

# Local dev placeholders only — replace before any shared or production deployment.
CLICKHOUSE_PASSWORD=changeme
POSTGRES_PASSWORD=changeme
REDIS_PASSWORD=changeme

# Опционально: веб-pgAdmin (docker compose --profile tools up -d pgadmin) → http://localhost:5050
# PGADMIN_EMAIL=pgadmin@example.com
# PGADMIN_PASSWORD=changeme-pgadmin

# Опционально: ключ для siem-parser (заголовок X-API-Key или Authorization: Bearer …)
# SIEM_PARSER_API_KEY=

# ── Threat intel (docker compose --profile intel up -d intel-connector) ─────────
# INTEL_MISP_URL=https://misp.example.com
# INTEL_MISP_API_KEY=
# INTEL_FEED_URL=https://example.com/iocs.json
# INTEL_POLL_INTERVAL_SEC=3600
# INTEL_SYNC_REDIS=1
# Парсер: матч source_ip по Redis SET siem:intel:ipv4
# SIEM__INTEL__REDIS_URL=redis://redis:6379/0
