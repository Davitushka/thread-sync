              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area"
      }
    },

    {
      "id": 37,
      "title": "Parse Error Rate (%)",
      "description": "Доля ошибок парсинга от общего потока. Thresholds: <1% норма, 1–5% предупреждение, >5% критично.",
      "type": "gauge",
      "gridPos": { "x": 6, "y": 43, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
          "expr": "rate(siem_parser_events_parsed_total{job=\"siem-parser\",status=\"error\"}[5m]) / rate(siem_parser_events_parsed_total{job=\"siem-parser\"}[5m]) * 100",
          "legendFormat": "Error %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      }
    },

    {
      "id": 38,
      "title": "Active Prometheus Alerts",
      "description": "Количество активных (firing) алертов в Prometheus Alertmanager.",
