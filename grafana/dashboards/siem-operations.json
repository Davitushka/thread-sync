    {
      "id": 310,
      "title": "ClickHouse: события профиля (запросы / с)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 7, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
      "description": "Counters из встроенного экспорта ClickHouse (`events` в prometheus.xml). Select/Insert — типичная нагрузка; FailedQuery — сбои выполнения.",
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
          "expr": "rate(ClickHouseProfileEvents_SelectQuery[2m])",
          "legendFormat": "SelectQuery / s"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
          "expr": "rate(ClickHouseProfileEvents_InsertQuery[2m])",
          "legendFormat": "InsertQuery / s"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
          "expr": "rate(ClickHouseProfileEvents_FailedQuery[2m])",
          "legendFormat": "FailedQuery / s"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "cps", "custom": { "lineWidth": 2, "fillOpacity": 12 } } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom" } }
    },
    {
      "id": 311,
      "title": "Redpanda: записей / с в topic siem.events",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 7, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
      "description": "Суммарная скорость записи записей по партициям (namespace kafka). DLQ — отдельный topic при необходимости.",
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
          "expr": "sum(rate(vectorized_cluster_partition_records_produced{namespace=\"kafka\",topic=\"siem.events\"}[2m]))",
          "legendFormat": "produced records/s"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "cps", "custom": { "lineWidth": 2, "fillOpacity": 15 } } },
      "options": { "tooltip": { "mode": "single" }, "legend": { "displayMode": "hidden" } }
    },
    {
      "id": 312,
      "title": "Redpanda: offset consumer group → ClickHouse (siem.events)",
      "type": "table",
      "gridPos": { "x": 0, "y": 15, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
      "description": "Текущие `vectorized_kafka_group_offset` для группы, которая читает в ingest в ClickHouse. Рост со временем при активном потреблении; при залипании — сравните с high watermark в Redpanda Console.",
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-siem" },
          "expr": "vectorized_kafka_group_offset{topic=\"siem.events\",group=\"clickhouse_siem_events\"}",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "renameByName": {
              "partition": "partition",
              "Value": "offset"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto", "inspect": false } },
        "overrides": []
      },
      "options": { "showHeader": true, "sortBy": [{ "displayName": "partition", "desc": false }] }
    },
